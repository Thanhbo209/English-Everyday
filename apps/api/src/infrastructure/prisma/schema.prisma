generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String             @id @default(uuid())
  email            String             @unique
  passwordHash     String
  name             String
  role             UserRole           @default(STUDENT)
  avatarUrl        String             @default("https://plus.unsplash.com/premium_photo-1739786996022-5ed5b56834e2?fm=jpg&q=60&w=3000&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxzZWFyY2h8MXx8ZGVmYXVsdCUyMGF2YXRhcnxlbnwwfHwwfHx8MA%3D%3D")
  xp               Int                @default(0)
  streak           Int                @default(0)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  classrooms       Classroom[]        @relation("TeacherClassrooms")
  classroomMembers ClassroomsMember[]
  vocabularySets   VocabularySet[]    @relation("TeacherVocabularySets")
}

model Classroom {
  id                String             @id @default(uuid())
  name              String
  description       String?
  teacherId         String
  joinCode          String             @unique
  status            ClassroomStatus    @default(ACTIVE)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  teacher           User               @relation("TeacherClassrooms", fields: [teacherId], references: [id])
  classroomsMembers ClassroomsMember[]
  vocabularySets    VocabularySet[]
}

model ClassroomsMember {
  id          String    @id @default(uuid())
  classroomId String
  studentId   String
  joinAt      DateTime  @default(now())
  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([classroomId, studentId])
}

enum UserRole {
  TEACHER
  STUDENT
}

enum ClassroomStatus {
  INACTIVE
  ACTIVE
}

enum PartOfSpeech {
  NOUN
  VERB
  ADJECTIVE
  ADVERB
  PRONOUN
  PREPOSITION
  CONJUNCTION
  INTERJECTION
  DETERMINER
}

model VocabularySet {
  id          String @id @default(uuid())
  classroomId String
  teacherId   String

  title       String
  language    String
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  teacher   User      @relation("TeacherVocabularySets", fields: [teacherId], references: [id], onDelete: Cascade)

  vocabItems VocabItem[]

  @@index([classroomId])
  @@index([teacherId])
  @@map("vocab_sets")
}

model VocabItem {
  id    String @default(uuid())
  setId String

  term       String
  definition String

  phonetic     String?
  partOfSpeech String

  exampleSentence String?
  imageUrl        String?
  audioUrl        String?

  orderIndex Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vocabSet VocabularySet @relation(fields: [setId], references: [id], onDelete: Cascade)

  @@unique([setId, orderIndex])
  @@index([setId])
  @@map("vocab_items")
}
