# ─────────────────────────────────────────────────────────
#  EnglishEveryday — Environment Variables
#  Copy this file to .env and fill in your values.
#  Never commit .env to git.
# ─────────────────────────────────────────────────────────

# ── PostgreSQL ──────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=englisheveryday
POSTGRES_USER=ee_user
POSTGRES_PASSWORD=ee_password

# Full connection string for Prisma
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}?schema=public"

# ── Redis ────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=ee_redis_pass

# Full Redis URL
REDIS_URL="redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}"

# ── API ──────────────────────────────────────────────────
NODE_ENV=development
API_PORT=3000
JWT_SECRET=change_this_to_a_secure_random_secret_at_least_32_chars
JWT_EXPIRES_IN=1h
